{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"root": true,
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!dist", "!build", "!.turbo"]
	},
	"formatter": {
		"lineWidth": 120,
		"indentStyle": "tab",
		"indentWidth": 2
	}
}
