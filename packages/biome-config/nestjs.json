{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"root": false,

	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!node_modules", "!dist", "!**/coverage"]
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,

			"style": {
				"noDefaultExport": "error",
				"useNodejsImportProtocol": "error",
				"useImportType": "off"
			},

			"suspicious": {
				"noConsole": "warn"
			}
		},

		"includes": ["**", "!dist/**", "!coverage/**"]
	},

	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		},
		"formatter": {
			"quoteStyle": "double"
		},
		"globals": ["process", "__dirname", "__filename", "Buffer", "global"]
	},

	"overrides": [
		{
			"includes": ["**/*.ts"],
			"linter": {
				"rules": {
					"complexity": {
						"noArguments": "error"
					},

					"style": {
						"useConst": "error"
					},

					"suspicious": {
						"noExplicitAny": "warn"
					}
				}
			}
		},
		{
			"includes": ["**/*.spec.ts", "**/*.test.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		}
	],

	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
