{
	"name": "slotty",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
		"check-types": "turbo run check-types",
		"db:generate": "turbo run db:generate"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"prettier": "^3.8.3",
		"taze": "^19.11.0",
		"turbo": "^2.9.8",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
