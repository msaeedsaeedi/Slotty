{
	"name": "api",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "node --loader ts-node/esm src/main.ts",
		"dev:watch": "node --watch --loader ts-node/esm src/main.ts",
		"build": "tsc -p tsconfig.build.json",
		"start": "node dist/main.js",
		"lint": "biome check --write",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"migration:run": "tsx ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:run",
		"migration:revert": "tsx ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:revert",
		"migration:show": "tsx ./node_modules/typeorm/cli.js -d src/database/data-source.ts migration:show"
	},
	"dependencies": {
		"@nestjs/common": "^10.0.0",
		"@nestjs/config": "^3.2.0",
		"@nestjs/core": "^10.0.0",
		"@nestjs/mapped-types": "^2.0.5",
		"@nestjs/platform-express": "^10.0.0",
		"@nestjs/swagger": "^7.3.0",
		"@nestjs/typeorm": "^10.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"joi": "^17.12.0",
		"pg": "^8.12.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"typeorm": "^0.3.22"
	},
	"devDependencies": {
		"@repo/biome-config": "^",
		"@repo/typescript-config": "*",
		"@types/node": "^22.15.3",
		"ts-node": "^10.9.2",
		"tsx": "^4.20.2",
		"typescript": "5.9.2"
	}
}
